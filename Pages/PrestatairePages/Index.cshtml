@page
@model ISH_APP.Pages.PrestatairePages.IndexModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Prestataires";
}

<div class="container-fluid py-5">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">🏢 Liste des prestataires</h2>
        <a asp-page="Create" class="btn btn-success">➕ Ajouter un prestataire</a>
    </div>

    <form method="get" class="row g-3 mb-4">
        <div class="col-md-4">
            <input type="text" name="NomSearch" value="@Model.NomSearch" class="form-control" placeholder="🔍 Rechercher par nom" />
        </div>
        <div class="col-md-4">
            <input type="text" name="ServiceSearch" value="@Model.ServiceSearch" class="form-control" placeholder="🔍 Rechercher par service" />
        </div>
        <div class="col-md-4 d-flex">
            <input type="text" name="VilleSearch" value="@Model.VilleSearch" class="form-control me-2" placeholder="🔍 Rechercher par ville" />
            <button type="submit" class="btn btn-outline-primary">Rechercher</button>
        </div>
    </form>

    <div class="table-responsive shadow-sm border rounded">
        <table class="table table-hover table-bordered align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Nom</th>
                    <th>Services</th>
                    <th>Agences</th>
                    <th>Contact</th>
                    <th>Email</th>
                    <th>Adresse siège</th>
                    <th>Code postal</th>
                    <th>Ville</th>
                    <th>Horaires</th>
                    <th>Site Web</th>
                    <th>Note</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Prestataire != null && Model.Prestataire.Any())
                {
                    foreach (var item in Model.Prestataire)
                    {
                        <tr onclick="window.location.href='@Url.Page("Details", new { id = item.PrestataireID })'" style="cursor: pointer;">
                            <td>@item.Nom</td>
                            <td>@item.Services</td>
                            <td>@item.Agences</td>
                            <td>@item.Contact</td>
                            <td>@item.Mail</td>
                            <td>@item.AdresseSiege</td>
                            <td>@item.CodePostalSiege</td>
                            <td>@item.VilleSiege</td>
                            <td>@item.Horaires</td>
                            <td>@item.SiteWeb</td>
                            <td>
                                @if (item.Note >= 4)
                                {
                                    <span class="badge bg-success">@item.Note</span>
                                }
                                else if (item.Note >= 2 && item.Note < 4)
                                {
                                    <span class="badge bg-warning text-dark">@item.Note</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">@item.Note</span>
                                }
                            </td>

                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@item.PrestataireID" onsubmit="return confirm('Supprimer ce prestataire ?');" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Supprimer</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="14" class="text-center text-muted">Aucun prestataire trouvé.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
