@page "{id:int}"
@model ISH_APP.Pages.ClientPages.EditModel
@{
    ViewData["Title"] = "Modifier le client";
}

<div class="container py-5">
    <h2 class="text-center mb-4">✏️ Modifier le Client</h2>

    <div class="card shadow-lg border-0">
        <div class="card-body p-4">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="Client.ClientID" />

                <h4 class="mb-3 border-bottom pb-2">📋 Informations personnelles</h4>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="Client.Nom" class="form-label fw-bold"></label>
                        <input asp-for="Client.Nom" class="form-control" />
                        <span asp-validation-for="Client.Nom" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Client.Prenom" class="form-label fw-bold"></label>
                        <input asp-for="Client.Prenom" class="form-control" />
                        <span asp-validation-for="Client.Prenom" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="Client.Telephone" class="form-label fw-bold"></label>
                        <input asp-for="Client.Telephone" class="form-control" />
                        <span asp-validation-for="Client.Telephone" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Client.Mail" class="form-label fw-bold"></label>
                        <input asp-for="Client.Mail" class="form-control" />
                        <span asp-validation-for="Client.Mail" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label asp-for="Client.Adresse" class="form-label fw-bold"></label>
                        <input asp-for="Client.Adresse" class="form-control" />
                        <span asp-validation-for="Client.Adresse" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Client.CodePostal" class="form-label fw-bold"></label>
                        <input asp-for="Client.CodePostal" class="form-control" />
                        <span asp-validation-for="Client.CodePostal" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Client.Ville" class="form-label fw-bold"></label>
                        <input asp-for="Client.Ville" class="form-control" />
                        <span asp-validation-for="Client.Ville" class="text-danger"></span>
                    </div>
                </div>

                <h4 class="mb-3 border-bottom pb-2">🛡️ Assurance</h4>
                <div class="row mb-4">
                    <div class="col-md-6">
                        <label asp-for="Client.AssuranceID" class="form-label fw-bold">Compagnie</label>
                        <select asp-for="Client.AssuranceID" asp-items="Model.AssuranceList" class="form-select">
                            <option value="">-- Sélectionner --</option>
                        </select>
                        <span asp-validation-for="Client.AssuranceID" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <button type="submit" class="btn btn-primary">💾 Enregistrer</button>
                    <a class="btn btn-secondary" asp-page="./Index">← Retour à la liste</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
