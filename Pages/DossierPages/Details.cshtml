@page
@model ISH_APP.Pages.DossierPages.DetailsModel
@{
    ViewData["Title"] = "Détails du Dossier";
    string priorityClass = Model.Dossier.Priorite switch
    {
        "Haute" => "badge bg-danger",
        "Moyenne" => "badge bg-warning text-dark",
        "Basse" => "badge bg-success",
        _ => "badge bg-secondary"
    };
}

<div class="container py-5">
    <h2 class="text-center mb-4">Détails du Dossier</h2>

    <div class="card shadow-lg border-0">
        <div class="card-body p-4">

            <!-- Informations générales -->
            <h4 class="mb-3 border-bottom pb-2">🧾 Informations générales</h4>
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <div class="p-3 border rounded shadow-sm">
                        <strong>Date de déclaration :</strong><br />
                        @Model.Dossier.DateDeclaration?.ToString("dd/MM/yyyy")
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="p-3 border rounded shadow-sm">
                        <strong>Type de sinistre :</strong><br />
                        @Model.Dossier.TypeSinistre
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="p-3 border rounded shadow-sm">
                        <strong>Priorité :</strong>
                        <span class="@priorityClass">@Model.Dossier.Priorite</span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="p-3 border rounded shadow-sm">
                        <strong>État :</strong>
                        @{
                            // Récupérer le prestataire assigné
                            var utilisateurPrestataire = Model.Dossier.DossierUtilisateurs?
                            .FirstOrDefault(du => du.Utilisateur != null && du.Utilisateur.Role == "Prestataire")?.Utilisateur;

                            // Déterminer dynamiquement l'état
                            string etatAffiche = (utilisateurPrestataire != null) ? "En cours" : Model.Dossier.Etat;
                        }

                        <span class="badge bg-info text-dark">@etatAffiche</span>

                    </div>
                </div>
                <div class="col-12">
                    <div class="p-3 border rounded shadow-sm">
                        <strong>Description :</strong><br />
                        <p class="text-muted mb-0">@Model.Dossier.Description</p>
                    </div>
                </div>
            </div>

            <!-- Parties impliquées -->
            <h4 class="mb-3 border-bottom pb-2">👥 Parties impliquées</h4>
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="p-3 border rounded shadow-sm">
                        <strong>👤 Client :</strong><br />
                        <a asp-page="/ClientPages/Details" asp-route-id="@Model.Dossier.ClientID">
                            @Model.Dossier.Client?.Nom @Model.Dossier.Client?.Prenom
                        </a>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3 border rounded shadow-sm">
                        <strong>🏢 Assurance :</strong><br />
                        @if (Model.UtilisateurAssurance != null)
                        {
                            <span>@Model.UtilisateurAssurance.Nom @Model.UtilisateurAssurance.Prenom</span>
                        }
                        else
                        {
                            <span class="text-muted fst-italic">Non assigné</span>
                        }
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3 border rounded shadow-sm">
                        <strong>🛠️ Prestataire :</strong><br />
                        @if (Model.UtilisateurPrestataire != null)
                        {
                            <span>@Model.UtilisateurPrestataire.Nom @Model.UtilisateurPrestataire.Prenom</span>
                        }
                        else
                        {
                            <span class="text-muted fst-italic">Non assigné</span>
                        }
                    </div>
                </div>
            </div>

